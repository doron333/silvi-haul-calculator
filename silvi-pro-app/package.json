{
  "name": "silvi-haul-rate-calculator",
  "version": "1.0.0",
  "description": "Professional Haul Rate Calculator for Construction Materials",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "haul",
    "rate",
    "calculator",
    "construction",
    "materials",
    "silvi"
  ],
  "author": "Silvi Materials",
  "license": "Commercial",
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.7.1"
  },
  "build": {
    "appId": "com.silvi.haulratecalculator",
    "productName": "Silvi Haul Rate Calculator Pro",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!.gitignore"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
