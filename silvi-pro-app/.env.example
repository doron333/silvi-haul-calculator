# API Keys Configuration
# Copy this file to .env and add your actual keys

# Anthropic Claude API Key
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# U.S. Energy Information Administration API Key (FREE)
# Get yours at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your-eia-api-key-here

# Optional: License Server URL (for production)
# LICENSE_SERVER_URL=https://your-license-server.com/api/verify
